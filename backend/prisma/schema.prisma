generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Amenity {
  id         Int      @id @default(autoincrement())
  name       String
  propertyId Int
  Property   Property @relation(fields: [propertyId], references: [id])
}

model Comment {
  id          Int      @id @default(autoincrement())
  content     String
  rating      Float
  propertyId  Int
  timestamp   DateTime @default(now())
  commenterId Int
  User        User     @relation(fields: [commenterId], references: [id])
  Property    Property @relation(fields: [propertyId], references: [id])
}

model NearbyPlace {
  id            Int      @id @default(autoincrement())
  name          String
  type          String
  distance      Float
  nearByPlaceId Int
  Property      Property @relation(fields: [nearByPlaceId], references: [id])
}

model Property {
  id                Int               @id @default(autoincrement())
  name              String
  address           String
  rent              Decimal           @db.Decimal(10, 2)
  deposit           Decimal?          @db.Decimal(10, 2)
  nsfasAccredited   Boolean           @default(false)
  gas               Int?
  water             Int?
  electricity       Int?
  about             String
  rules             String
  landlordId        Int
  createdAt         DateTime          @default(now())
  genderRestriction GenderRestriction
  propertyType      PropertyType
  updatedAt         DateTime          @updatedAt
  suburb            String
  town              String
  Amenities         Amenity[]
  Comments          Comment[]
  NearbyPlaces      NearbyPlace[]
  User              User              @relation(fields: [landlordId], references: [id])

  @@index([propertyType])
  @@index([rent])
}

model User {
  id         Int        @id @default(autoincrement())
  username   String
  email      String     @unique
  password   String
  role       Role       @default(TENANT)
  Comments   Comment[]
  Properties Property[]
}

enum GenderRestriction {
  Male
  Female
  Mixed
}

enum PropertyType {
  SingleBackroom
  SharingBackroom
  Apartment
  SharingApartment
  SingeFlat
  Flat
}

enum Role {
  LANDLORD
  TENANT
}
