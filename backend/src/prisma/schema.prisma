generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Amenity {
  id         Int      @id @default(autoincrement())
  name       String
  propertyId Int
  Property   Property @relation(fields: [propertyId], references: [id])
}

model Comment {
  id          Int      @id @default(autoincrement())
  content     String
  rating      Float
  propertyId  Int
  timestamp   DateTime @default(now())
  commenterId Int
  User        User     @relation(fields: [commenterId], references: [id])
  Property    Property @relation(fields: [propertyId], references: [id])
}

model NearbyPlace {
  id            Int      @id @default(autoincrement())
  name          String
  type          String
  distance      Float
  nearByPlaceId Int
  Property      Property @relation(fields: [nearByPlaceId], references: [id])
}

model Property {
  id                Int               @id @default(autoincrement())
  name              String
  address           String
  rent              Decimal           @db.Decimal(10, 2)
  deposit           Decimal?          @db.Decimal(10, 2)
  nsfasAccredited   Boolean           @default(false)
  gas               Int?
  water             Int?
  electricity       Int?
  about             String
  rules             String
  landlordId        Int
  createdAt         DateTime          @default(now())
  genderRestriction GenderRestriction
  propertyType      PropertyType
  updatedAt         DateTime
  surburb           String
  town              String
  Amenity           Amenity[]
  Comment           Comment[]
  NearbyPlace       NearbyPlace[]
  User              User              @relation(fields: [landlordId], references: [id])

  @@index([propertyType])
  @@index([rent])
}

model User {
  id       Int        @id @default(autoincrement())
  username String     @unique
  email    String     @unique
  password String
  role     Role       @default(TENANT)
  Comment  Comment[]
  Property Property[]
}

enum GenderRestriction {
  MALE_ONLY
  FEMALE_ONLY
  MIXED
}

enum PropertyType {
  SINGLE
  SHARING
}

enum Role {
  LANDLORD
  TENANT
}
